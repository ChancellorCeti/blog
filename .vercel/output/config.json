{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/layouts/Layout/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/layouts/MarkdownPostLayout/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/movies-and-tv/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/projects/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/recommended-content/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/rss\\.xml$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/tags/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/404/?$",
			"dest": "/_isr?x_astro_path=$0"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}